// v0.2e: 함수 + 재귀.

함수 더하기(a, b) -> 합 {
    돌려주기 a + b.
}

함수 팩토리얼(n) -> 결과 {
    만약 (n <= 1) 이면 {
        돌려주기 1.
    }
    돌려주기 n * 팩토리얼(n - 1).
}

함수 피보(n) -> 결과 {
    만약 (n < 2) 이면 {
        돌려주기 n.
    }
    돌려주기 피보(n - 1) + 피보(n - 2).
}

보여주기("3 + 4 = ").
보여주기(더하기(3, 4)).

보여주기("5! = ").
보여주기(팩토리얼(5)).

보여주기("피보(10) = ").
보여주기(피보(10)).

// 지역 변수 + 반복 조합
함수 합계(n) -> 결과 {
    변수 합 = 0.
    변수 i = 1.
    동안 (i <= n) {
        변수 합 = 합 + i.
        변수 i = i + 1.
    }
    돌려주기 합.
}
보여주기("1+2+...+10 = ").
보여주기(합계(10)).
