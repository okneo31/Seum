// 시간 그릇 — v0.3e Path B 깊은 자기-검증.
// 결정 #46 그릇 ≡ 담음. 결정 #58 native_시각_시스템_초 만 native. SST 포맷팅은 .세움 안.
// v0.2 의 value.cc::format_sst / decompose 와 *동일 결과* 산출.

// === 자리수 한글 표현 ===

함수 자리_문자(자리) -> 결과 {
    만약 (자리 == 0) 이면 { 돌려주기 "0". }
    만약 (자리 == 1) 이면 { 돌려주기 "1". }
    만약 (자리 == 2) 이면 { 돌려주기 "2". }
    만약 (자리 == 3) 이면 { 돌려주기 "3". }
    만약 (자리 == 4) 이면 { 돌려주기 "4". }
    만약 (자리 == 5) 이면 { 돌려주기 "5". }
    만약 (자리 == 6) 이면 { 돌려주기 "6". }
    만약 (자리 == 7) 이면 { 돌려주기 "7". }
    만약 (자리 == 8) 이면 { 돌려주기 "8". }
    돌려주기 "9".
}

함수 정수_문자열(n) -> 결과 {
    만약 (n == 0) 이면 { 돌려주기 "0". }

    변수 음수 = 거짓.
    만약 (n < 0) 이면 {
        변수 음수 = 참.
        변수 n = -n.
    }

    변수 결과 = "".
    동안 (n > 0) {
        변수 결과 = 자리_문자(n % 10) + 결과.
        변수 n = n / 10.
    }

    만약 (음수) 이면 { 변수 결과 = "-" + 결과. }
    돌려주기 결과.
}

함수 두자리(n) -> 결과 {
    만약 (n < 10) 이면 { 돌려주기 "0" + 정수_문자열(n). }
    돌려주기 정수_문자열(n).
}

// === 달력 계산 ===

함수 윤년인가(년) -> 결과 {
    만약 (년 % 400 == 0) 이면 { 돌려주기 참. }
    만약 ((년 % 4 == 0) && (년 % 100 != 0)) 이면 { 돌려주기 참. }
    돌려주기 거짓.
}

함수 월의_일수(년, 월) -> 결과 {
    만약 (월 == 2) 이면 {
        만약 (윤년인가(년)) 이면 { 돌려주기 29. }
        돌려주기 28.
    }
    만약 (월 == 4) 이면 { 돌려주기 30. }
    만약 (월 == 6) 이면 { 돌려주기 30. }
    만약 (월 == 9) 이면 { 돌려주기 30. }
    만약 (월 == 11) 이면 { 돌려주기 30. }
    돌려주기 31.
}

// SST 초 → 한글 포맷.
// SST epoch = 1945-08-15 06:00 KST. 양수 일수만 v0.3e 처리.
함수 형식화_SST(s) -> 결과 {
    변수 일수 = s / 86400.
    변수 나머지 = s % 86400.

    // SST epoch 가 KST 06:00 이므로 +6시간 보정 (잠긴 결정 #14).
    변수 나머지 = 나머지 + 6 * 3600.
    만약 (나머지 >= 86400) 이면 {
        변수 나머지 = 나머지 - 86400.
        변수 일수 = 일수 + 1.
    }

    변수 시 = 나머지 / 3600.
    변수 분 = (나머지 % 3600) / 60.
    변수 초b = 나머지 % 60.

    // 일수 → 년/월/일 (1945-08-15 기준)
    변수 년 = 1945.
    변수 월 = 8.
    변수 일 = 15.

    동안 (일수 > 0) {
        변수 dim = 월의_일수(년, 월).
        변수 남은 = dim - 일.
        만약 (일수 <= 남은) 이면 {
            변수 일 = 일 + 일수.
            변수 일수 = 0.
        }
        아니면 {
            변수 일수 = 일수 - (남은 + 1).
            변수 일 = 1.
            변수 월 = 월 + 1.
            만약 (월 > 12) 이면 {
                변수 월 = 1.
                변수 년 = 년 + 1.
            }
        }
    }

    변수 세움력년 = 년 - 1945.

    돌려주기 "세움력 " + 정수_문자열(세움력년) + "년 "
           + 정수_문자열(월) + "월 "
           + 정수_문자열(일) + "일 "
           + 두자리(시) + ":" + 두자리(분) + ":" + 두자리(초b) + " SST".
}

지연값 지금() -> 결과 {
    돌려주기 형식화_SST(위험 { native_시각_시스템_초() }).
}
